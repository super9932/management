# send-src 스크립트용 SMTP 설정 — 이 파일을 .env.local 로 복사해 값을 채운다.
# .env.local 은 .gitignore 로 커밋되지 않는다 (시크릿 — S-01/E-03).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
# Gmail 은 계정 비밀번호가 아니라 "앱 비밀번호"를 사용한다.
SMTP_PASS=your-app-password
# 발신자 표기 (생략 시 SMTP_USER). 수신처(to)는 실행 인자로 자유롭게 지정한다.
MAIL_FROM=your-account@gmail.com
